    {
      "parameters": {
        "jsCode": "const record = $input.first().json;\nconst contenido = record.fields['Contenido Generado'];\nconst recordId = record.id;\nconst ideaSemilla = record.fields['Idea Semilla'];\nconst autor = record.fields['Autor'] || 'Cuenta Principal';\n\n// Detectamos si subiste la imagen en la nueva columna de Airtable\nconst imagenesAttachment = record.fields['Imagen'] || [];\nconst tieneImagen = imagenesAttachment.length > 0;\nconst urlImagen = tieneImagen ? imagenesAttachment[0].url : null;\n\n// Armamos la estructura base para LinkedIn\nconst postPayload = {\n  author: `urn:li:person:www.linkedin.com/in/norberto-loyola`, // Recordá que acá irá tu ID de perfil real\n  lifecycleState: 'PUBLISHED',\n  specificContent: {\n    'com.linkedin.ugc.ShareContent': {\n      shareCommentary: {\n        text: contenido\n      },\n      // Si hay imagen cambia a 'IMAGE', de lo contrario se publica como texto plano ('NONE')\n      shareMediaCategory: tieneImagen ? 'IMAGE' : 'NONE'\n    }\n  },\n  visibility: {\n    'com.linkedin.ugc.MemberNetworkVisibility': 'PUBLIC'\n  }\n};\n\n// Si hay una imagen válida en Airtable, se la inyectamos al paquete de LinkedIn\nif (tieneImagen) {\n  postPayload.specificContent['com.linkedin.ugc.ShareContent'].media = [\n    {\n      status: 'READY',\n      description: {\n        text: ideaSemilla || 'Post de Contenido Automático'\n      },\n      originalUrl: urlImagen,\n      title: {\n        text: 'Imagen del Post'\n      }\n    }\n  ];\n}\n\nreturn [{\n  json: {\n    recordId,\n    ideaSemilla,\n    autor,\n    contenido,\n    postPayload,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "843495da-9759-4282-8fa6-15788ab70961",
      "name": "Preparar Payload LinkedIn",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
